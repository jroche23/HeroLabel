Data Model
Workspace
{
  id: string,
  name: string,
  color: string (hex),
  description: string,
  createdAt: ISO date string,
  isArchived: boolean
}
Project
{
  id: string,
  name: string,
  description: string,
  workspaceId: string,
  color: string (hex, from 8-color palette),
  labelConfig: string (XML template — stored as string),
  createdAt: ISO date string,
  updatedAt: ISO date string,
  createdBy: string (user ID),
  settings: {
    annotation: { ... },
    review: { ... },
    quality: { ... }
  }
}
Task
{
  id: string (numeric-looking, e.g., "245231207"),
  projectId: string,
  data: { 
    // Dynamic fields based on project template
    // e.g., html: "<full html string>", search_query: "Mono", ...
  },
  completedCount: number,
  cancelledCount: number,
  predictionsCount: number,
  isStarred: boolean,
  createdAt: ISO date string
}
Annotation
{
  id: string,
  taskId: string,
  userId: string,
  result: [
    {
      id: string,
      type: "choices",
      from_name: "relevance",
      to_name: "content",
      value: { choices: ["Fully Meets Intent"] }
    }
  ],
  createdAt: ISO date string,
  updatedAt: ISO date string,
  status: "submitted" | "draft" | "skipped"
}
User
{
  id: string,
  email: string,
  initials: string (2 chars),
  color: string (hex — avatar background color),
  role: "admin" | "annotator" | "reviewer"
}

